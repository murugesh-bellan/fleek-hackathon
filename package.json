{
  "name": "abhi-and-sanket",
  "version": "0.1.0",
  "description": "WhatsApp-native Fleek buyer (Abhi) and supplier (Sanket) agents (a16z x Fleek hackathon)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "seed": "tsx src/scripts/seed.ts",
