    "search:image": "tsx src/scripts/search-image.ts",
    "demo": "tsx src/scripts/demo.ts",
    "chat": "tsx src/scripts/chat.ts",
    "start": "tsx src/server.ts",
    "serve": "tsx src/server.ts",
    "register": "tsx src/scripts/register.ts",
