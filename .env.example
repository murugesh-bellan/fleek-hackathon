# LLM provider (OpenAI-compatible API)
LLM_PROVIDER=cerebras
LLM_API_KEY=
LLM_BASE_URL=https://api.cerebras.ai/v1

# Model IDs
MODEL_REASONING=gemma-4-31b
MODEL_FAST=gemma-4-31b

# Wassist (WhatsApp transport) — needed only for real WhatsApp
WASSIST_API_KEY=
# Wassist platform API (register BYOA, etc.) — NOT your ngrok/Railway URL
WASSIST_BASE_URL=https://wassist.app
# Optional. Signing secret for Wassist *platform* webhooks (dashboard → Developers → Webhooks).
# Leave EMPTY for BYOA — BYOA deliveries are unsigned. If set, unsigned inbound gets 401.
# Do not put WASSIST_API_KEY here. Abhi replies via webhook JSON + reply_callback, not Send Message.
WASSIST_WEBHOOK_SECRET=
# YOUR public webhook that Wassist POSTs to:
#   Railway: https://<service>.up.railway.app/webhook
#   Local:   https://<subdomain>.ngrok-free.app/webhook
PUBLIC_WEBHOOK_URL=

# Local server
PORT=8787
# Structured logs: debug | info | warn | error (default info). HTTP via hono/logger.
LOG_LEVEL=info

# WhatsApp number for the landing-page wa.me CTA (digits only; default = sandbox)
WHATSAPP_NUMBER=447424845871

# Postgres (Railway public URL or internal DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/railway
